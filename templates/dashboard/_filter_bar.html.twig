{% if unreadOnly %}
    <a hx-get="{{ path('app_dashboard', {category: currentCategory, source: currentSource|default(null), bookmarkedOnly: bookmarkedOnly|default(false) ? 1 : 0}) }}"
       hx-target="#article-feed"
       hx-swap="innerHTML"
       hx-push-url="true"
       hx-indicator="#feed-loader"
       class="btn btn-sm btn-outline btn-active">Unread Only</a>
{% else %}
    <a hx-get="{{ path('app_dashboard', {category: currentCategory, source: currentSource|default(null), unreadOnly: 1, bookmarkedOnly: bookmarkedOnly|default(false) ? 1 : 0}) }}"
       hx-target="#article-feed"
       hx-swap="innerHTML"
       hx-push-url="true"
       hx-indicator="#feed-loader"
       class="btn btn-sm btn-outline">Unread Only</a>
{% endif %}
{% if bookmarkedOnly|default(false) %}
    <a hx-get="{{ path('app_dashboard', {category: currentCategory, source: currentSource|default(null), unreadOnly: unreadOnly ? 1 : 0}) }}"
       hx-target="#article-feed"
       hx-swap="innerHTML"
       hx-push-url="true"
       hx-indicator="#feed-loader"
       class="btn btn-sm btn-outline btn-active">Bookmarked</a>
{% else %}
    <a hx-get="{{ path('app_dashboard', {category: currentCategory, source: currentSource|default(null), unreadOnly: unreadOnly ? 1 : 0, bookmarkedOnly: 1}) }}"
       hx-target="#article-feed"
       hx-swap="innerHTML"
       hx-push-url="true"
       hx-indicator="#feed-loader"
       class="btn btn-sm btn-outline">Bookmarked</a>
{% endif %}
<button hx-post="{{ path('app_articles_read_all') }}"
        hx-target="#article-feed"
        hx-swap="innerHTML"
        hx-indicator="#feed-loader"
        hx-headers='{"X-CSRF-Token": "{{ csrf_token('mark_all_read') }}"}'
        class="btn btn-sm btn-ghost">Mark All Read</button>
<label class="flex items-center gap-1 cursor-pointer">
    <input type="checkbox" id="select-all-checkbox" class="checkbox checkbox-sm">
    <span class="text-sm">All</span>
</label>
<button id="bulk-delete-btn"
        hx-post="{{ path('app_articles_bulk_delete') }}"
        hx-include="input[name='article_ids[]']:checked"
        hx-headers='{"X-CSRF-Token": "{{ csrf_token('bulk_delete_articles') }}"}'
        hx-confirm="Delete selected articles?"
        hx-target="#article-feed"
        hx-swap="innerHTML"
        hx-indicator="#feed-loader"
        disabled
        class="btn btn-sm btn-error btn-outline">Remove Selected</button>
<span class="border-l border-base-300 pl-3 flex-1">
    <input id="article-filter" type="text" placeholder="Filter this page..." class="input input-bordered input-sm w-full" />
</span>
